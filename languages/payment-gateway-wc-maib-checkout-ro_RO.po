msgid "Payment notification callback"
msgstr "Notificare de plată"

#: includes/class-wc-gateway-maib-checkout.php:602
msgid "Callback signature validation failed."
msgstr "Validarea semnăturii de notificare plată a eșuat."

#. translators: 1: Order ID, 2: Payment method title
#: includes/class-wc-gateway-maib-checkout.php:631
#, php-format
msgid "Order not found by Order ID: %1$d received from %2$s."
msgstr "Comanda nu a fost gasită după Order ID: %1$d primit de la %2$s."

#. translators: 1: Order ID, 2: Meta field key
#: includes/class-wc-gateway-maib-checkout.php:662
#: includes/class-wc-gateway-maib-checkout.php:807
#, php-format
msgid "Order #%1$s missing meta field %2$s."
msgstr "Comanda #%1$s lipsește câmpul meta %2$s."

#. translators: 1: Order ID, 2: Payment method title, 3: Payment status
#: includes/class-wc-gateway-maib-checkout.php:699
#, php-format
msgid "Order #%1$s %2$s payment status: %3$s"
msgstr "Starea plății comenzii #%1$s prin %2$s: %3$s"

#. translators: 1: Order ID
#: includes/class-wc-gateway-maib-checkout.php:713
#, php-format
msgid "Order #%1$s payment check failed."
msgstr "Verificarea plății pentru comanda #%1$s a eșuat."

#. translators: 1: Payment data order ID, 2: Payment data price, 3: Order ID, 4: Order total price
#: includes/class-wc-gateway-maib-checkout.php:746
#, php-format
msgid "Order payment data mismatch: Payment: #%1$s %2$s, Order: #%3$s %4$s."
msgstr ""
"Date de plată comandă incorecte: Plata: #%1$s %2$s, Comanda: #%3$s %4$s."

#. translators: 1: Order ID
#: includes/class-wc-gateway-maib-checkout.php:754
#, php-format
msgid "Order #%1$s already fully paid."
msgstr "Comanda #%1$s este deja plătită integral."

#. translators: 1: Order ID, 2: Payment method title, 3: Payment data
#: includes/class-wc-gateway-maib-checkout.php:773
#, php-format
msgid "Order #%1$s payment completed via %2$s: %3$s"
msgstr "Plata comenzii #%1$s a fost finalizată prin %2$s: %3$s"

#. translators: 1: Order ID, 2: Refund amount, 3: Payment method title
#: includes/class-wc-gateway-maib-checkout.php:837
#, php-format
msgid "Order #%1$s refund of %2$s via %3$s approved."
msgstr ""
"Rambursarea comenzii #%1$s în valoare de %2$s prin %3$s a fost aprobată."

#. translators: 1: Order ID, 2: Refund amount, 3: Payment method title
#: includes/class-wc-gateway-maib-checkout.php:853
#, php-format
msgid "Order #%1$s refund of %2$s via %3$s failed."
msgstr "Rambursarea comenzii #%1$s în valoare de %2$s prin %3$s a eșuat."

#. translators: 1: Payment method title
#: includes/class-wc-gateway-maib-checkout.php:876
#, php-format
msgid "Check %1$s order payment"
msgstr "Verifică plata comenzii prin %1$s"

