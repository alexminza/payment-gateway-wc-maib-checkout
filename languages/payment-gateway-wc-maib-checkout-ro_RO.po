#. Plugin Name of the plugin
#: payment-gateway-wc-maib-checkout.php
msgid "Payment Gateway for maib e-Commerce Checkout for WooCommerce"
msgstr "Gateway de plată pentru maib e-Commerce Checkout pentru WooCommerce"

#. Description of the plugin
#: payment-gateway-wc-maib-checkout.php
msgid ""
"Accept Visa, Mastercard, Apple Pay, Google Pay, MIA Instant Payments "
"directly on your store with the maib e-Commerce Checkout payment gateway for "
"WooCommerce."
msgstr ""
"Acceptați Visa, Mastercard, Apple Pay, Google Pay, MIA plăți instant direct "
"în magazin cu gateway-ul de plată maib e-Commerce Checkout pentru "
"WooCommerce."

#: payment-gateway-wc-maib-checkout.php:80
msgid "Accept maib e-Commerce Checkout payments."
msgstr "Acceptați plăți prin maib e-Commerce Checkout."

#: payment-gateway-wc-maib-checkout.php:122
msgid "Enable/Disable"
msgstr "Activare/Dezactivare"

#: payment-gateway-wc-maib-checkout.php:124
msgid "Enable this gateway"
msgstr "Activează acest gateway de plată"

#: payment-gateway-wc-maib-checkout.php:128
msgid "Title"
msgstr "Titlu"

#: payment-gateway-wc-maib-checkout.php:130
msgid "Payment method title that the customer will see during checkout."
msgstr "Titlul metodei de plată afișat clientului în timpul plății."

#: payment-gateway-wc-maib-checkout.php:138
msgid "Description"
msgstr "Descriere"

#: payment-gateway-wc-maib-checkout.php:140
msgid "Payment method description that the customer will see during checkout."
msgstr "Descrierea metodei de plată afișată clientului în timpul plății."

#: payment-gateway-wc-maib-checkout.php:142
msgid "Visa, Mastercard, Apple Pay, Google Pay, MIA Instant Payments."
msgstr "Visa, Mastercard, Apple Pay, Google Pay, MIA plăți instant."

#: payment-gateway-wc-maib-checkout.php:146
msgid "Test mode"
msgstr "Mod testare"

#: payment-gateway-wc-maib-checkout.php:148
msgid "Enabled"
msgstr "Activat"

#: payment-gateway-wc-maib-checkout.php:149
msgid ""
"Use Test or Live bank gateway to process the payments. Disable when ready to "
"accept live payments."
msgstr ""
"Conectare la mediul de Test sau Producție al băncii pentru procesarea "
"plăților. Dezactivați atunci când sunteți gata să acceptați plăți reale."

#: payment-gateway-wc-maib-checkout.php:154
msgid "Debug mode"
msgstr "Mod depanare"

#: payment-gateway-wc-maib-checkout.php:156
msgid "Enable logging"
msgstr "Activează jurnalizare"

#: payment-gateway-wc-maib-checkout.php:157
msgid "View logs"
msgstr "Vizualizați jurnalele"

#: payment-gateway-wc-maib-checkout.php:158
msgid ""
"Save debug messages to the WooCommerce System Status logs. Note: this may "
"log personal information. Use this for debugging purposes only and delete "
"the logs when finished."
msgstr ""
"Salvare mesaje de depanare în logurile de stare sistem ale WooCommerce. "
"Notă: acest lucru poate înregistra informații personale. Utilizați această "
"opțiune numai pentru depanare și ștergeți jurnalele atunci când ați terminat."

#: payment-gateway-wc-maib-checkout.php:163
msgid "Order description"
msgstr "Descriere comandă"

#. translators: 1: Example placeholder shown to user, represents Order ID
#: payment-gateway-wc-maib-checkout.php:166
#, php-format
msgid "Format: <code>%1$s</code> - Order ID"
msgstr "Format: <code>%1$s</code> - ID Comandă"

#: payment-gateway-wc-maib-checkout.php:167
msgid "Order description that the customer will see in the app during payment."
msgstr ""
"Descrierea comenzii pe care clientul o va vedea în aplicație în timpul "
"plății."

#: payment-gateway-wc-maib-checkout.php:175
#: payment-gateway-wc-maib-checkout.php:286
msgid "Connection Settings"
msgstr "Setări conexiune"

#: payment-gateway-wc-maib-checkout.php:176
msgid "Payment gateway connection credentials are provided by the bank."
msgstr "Datele de conectare la gateway-ul de plată sunt furnizate de bancă."

#: payment-gateway-wc-maib-checkout.php:180
msgid "Client ID"
msgstr "Codul clientului"

#: payment-gateway-wc-maib-checkout.php:188
msgid "Client Secret"
msgstr "Cheia secretă a clientului"

#: payment-gateway-wc-maib-checkout.php:196
msgid "Signature Key"
msgstr "Cheia de semnătură"

#: payment-gateway-wc-maib-checkout.php:205
msgid "Payment Notification"
msgstr "Notificare plăți"

#: payment-gateway-wc-maib-checkout.php:209
msgid "Callback URL"
msgstr "URL apel invers"

#: payment-gateway-wc-maib-checkout.php:273
msgid "Unsupported store currency"
msgstr "Valuta magazinului nu este suportată"

#: payment-gateway-wc-maib-checkout.php:275
msgid "Supported currencies"
msgstr "Valute suportate"

#. translators: 1: Plugin installation instructions URL
#: payment-gateway-wc-maib-checkout.php:285
#, php-format
msgid ""
"See plugin documentation for <a href=\"%1$s\" target=\"_blank\">installation "
"instructions</a>."
msgstr ""
"Consultați documentația modulului pentru <a href=\"%1$s\" "
"target=\"_blank\">instrucțiuni de instalare</a>."

#: payment-gateway-wc-maib-checkout.php:286
msgid "Not configured"
msgstr "Neconfigurat"

#. translators: 1: Field label
#: payment-gateway-wc-maib-checkout.php:306
#, php-format
msgid "%1$s field must be set."
msgstr "Câmpul %1$s trebuie setat."

#. translators: 1: Payment method title, 2: Plugin settings URL
#: payment-gateway-wc-maib-checkout.php:360
#, php-format
msgid ""
"%1$s is not properly configured. Verify plugin <a href=\"%2$s\">Connection "
"Settings</a>."
msgstr ""
"%1$s nu este configurat corect. Verificați <a href=\"%2$s\">Setările de "
"conexiune</a>."

#. translators: 1: Payment method title, 2: Plugin settings URL
#: payment-gateway-wc-maib-checkout.php:367
#, php-format
msgid ""
"See <a href=\"%2$s\">%1$s settings</a> page for log details and setup "
"instructions."
msgstr ""
"Consultați pagina de <a href=\"%2$s\">setări %1$s</a> pentru vizualizarea "
"jurnalului și instrucțiuni de configurare."

#. translators: 1: Order ID, 2: Payment method title, 3: API response details
#: payment-gateway-wc-maib-checkout.php:630
#, php-format
msgid "Order #%1$s payment initiated via %2$s: %3$s"
msgstr "Plata comenzii #%1$s a fost inițiată prin %2$s: %3$s"

#. translators: 1: Order ID, 2: Payment method title
#: payment-gateway-wc-maib-checkout.php:649
#, php-format
msgid "Order #%1$s payment initiation failed via %2$s."
msgstr "Inițierea plății comenzii #%1$s prin %2$s a eșuat."

#. translators: 1: Payment method title
