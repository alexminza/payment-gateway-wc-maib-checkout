#. Plugin Name of the plugin
#: payment-gateway-wc-maib-checkout.php
msgid "Payment Gateway for maib e-Commerce Checkout for WooCommerce"
msgstr "Gateway de plată pentru maib e-Commerce Checkout pentru WooCommerce"

#. Description of the plugin
#: payment-gateway-wc-maib-checkout.php
msgid ""
"Accept Visa, Mastercard, Apple Pay, Google Pay, MIA Instant Payments "
"directly on your store with the maib e-Commerce Checkout payment gateway for "
"WooCommerce."
msgstr ""
"Acceptați Visa, Mastercard, Apple Pay, Google Pay, MIA plăți instant direct "
"în magazin cu gateway-ul de plată maib e-Commerce Checkout pentru "
"WooCommerce."

#: includes/class-wc-gateway-maib-checkout.php:52
msgid "Accept maib e-Commerce Checkout payments."
msgstr "Acceptați plăți prin maib e-Commerce Checkout."

#: includes/class-wc-gateway-maib-checkout.php:85
msgid "Enable/Disable"
msgstr "Activare/Dezactivare"

#: includes/class-wc-gateway-maib-checkout.php:87
msgid "Enable this gateway"
msgstr "Activează acest gateway de plată"

#: includes/class-wc-gateway-maib-checkout.php:91
msgid "Title"
msgstr "Titlu"

#: includes/class-wc-gateway-maib-checkout.php:93
msgid "Payment method title that the customer will see during checkout."
msgstr "Titlul metodei de plată afișat clientului în timpul plății."

#: includes/class-wc-gateway-maib-checkout.php:101
msgid "Description"
msgstr "Descriere"

#: includes/class-wc-gateway-maib-checkout.php:103
msgid "Payment method description that the customer will see during checkout."
msgstr "Descrierea metodei de plată afișată clientului în timpul plății."

#: includes/class-wc-gateway-maib-checkout.php:105
msgid "Visa, Mastercard, Apple Pay, Google Pay, MIA Instant Payments."
msgstr "Visa, Mastercard, Apple Pay, Google Pay, MIA plăți instant."

#: includes/class-wc-gateway-maib-checkout.php:109
msgid "Test mode"
msgstr "Mod testare"

#: includes/class-wc-gateway-maib-checkout.php:111
msgid "Enabled"
msgstr "Activat"

#: includes/class-wc-gateway-maib-checkout.php:112
msgid ""
"Use Test or Live bank gateway to process the payments. Disable when ready to "
"accept live payments."
msgstr ""
"Conectare la mediul de Test sau Producție al băncii pentru procesarea "
"plăților. Dezactivați atunci când sunteți gata să acceptați plăți reale."

#: includes/class-wc-gateway-maib-checkout.php:117
msgid "Debug mode"
msgstr "Mod depanare"

#: includes/class-wc-gateway-maib-checkout.php:119
msgid "Enable logging"
msgstr "Activează jurnalizare"

#: includes/class-wc-gateway-maib-checkout.php:120
msgid "View logs"
msgstr "Vizualizați jurnalele"

#: includes/class-wc-gateway-maib-checkout.php:121
msgid ""
"Save debug messages to the WooCommerce System Status logs. Note: this may "
"log personal information. Use this for debugging purposes only and delete "
"the logs when finished."
msgstr ""
"Salvare mesaje de depanare în logurile de stare sistem ale WooCommerce. "
"Notă: acest lucru poate înregistra informații personale. Utilizați această "
"opțiune numai pentru depanare și ștergeți jurnalele atunci când ați terminat."

#: includes/class-wc-gateway-maib-checkout.php:126
msgid "Order description"
msgstr "Descriere comandă"

#. translators: 1: Example placeholder shown to user, represents Order ID
#: includes/class-wc-gateway-maib-checkout.php:129
#, php-format
msgid "Format: <code>%1$s</code> - Order ID"
msgstr "Format: <code>%1$s</code> - ID Comandă"

#: includes/class-wc-gateway-maib-checkout.php:130
msgid "Order description that the customer will see in the app during payment."
msgstr ""
"Descrierea comenzii pe care clientul o va vedea în aplicație în timpul "
"plății."

#: includes/class-wc-gateway-maib-checkout.php:138
#: vendor/alexminza/wc-payment-gateway-base/src/WC_Payment_Gateway/WC_Payment_Gateway_Base.php:103
msgid "Connection Settings"
msgstr "Setări conexiune"

#: includes/class-wc-gateway-maib-checkout.php:139
msgid "Payment gateway connection credentials are provided by the bank."
msgstr "Datele de conectare la gateway-ul de plată sunt furnizate de bancă."

#: includes/class-wc-gateway-maib-checkout.php:143
msgid "Client ID"
msgstr "Codul clientului"

#: includes/class-wc-gateway-maib-checkout.php:151
msgid "Client Secret"
msgstr "Cheia secretă a clientului"

#: includes/class-wc-gateway-maib-checkout.php:159
msgid "Signature Key"
msgstr "Cheia de semnătură"

#: includes/class-wc-gateway-maib-checkout.php:168
msgid "Payment Notification"
msgstr "Notificare plăți"

#: includes/class-wc-gateway-maib-checkout.php:172
msgid "Callback URL"
msgstr "URL apel invers"

